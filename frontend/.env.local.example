# Backend API Configuration
# Replace with your actual API Gateway URL after deploying backend

# Get this URL by running: cd lambdas && sam deploy
# Look for "PricingAPIEndpoint" in the Outputs section

NEXT_PUBLIC_API_URL=https://YOUR-API-ID.execute-api.us-east-1.amazonaws.com
API_GATEWAY_URL=https://YOUR-API-ID.execute-api.us-east-1.amazonaws.com

# Optional: API Key (if you enable API Gateway authentication)
# API_GATEWAY_KEY=your-api-key-here
